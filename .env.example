# --- CycleCore PQ API ---------------------------------------------------------
# API key for /v1/sign and /v1/attest endpoints. Free tier: 1,000 ops/day.
# Register: POST https://pq-api.cyclecore.ai/v1/auth/register
# Reference: https://pq-api.cyclecore.ai/openapi.json
CYCLECORE_PQ_API_KEY=

# Base URL for the PQ API. Defaults to the public service.
# Override to point at a self-hosted, on-prem, or appliance-served compatible
# endpoint (e.g. for airgapped or compliance-restricted deployments). Any
# server implementing the public OpenAPI spec at the URL above works.
# CYCLECORE_PQ_BASE_URL=https://pq-api.cyclecore.ai

# --- CycleCore SecurityGates API ---------------------------------------------
# Optional API key (demo endpoint accepts unauthenticated calls).
# Reference: https://sg-api.cyclecore.ai/docs
CYCLECORE_SG_API_KEY=

# Base URL for the SecurityGates API. Override for self-hosted / on-prem /
# appliance deployments — any server implementing the public OpenAPI spec works.
# CYCLECORE_SG_BASE_URL=https://sg-api.cyclecore.ai

# --- Local LLM via Ollama -----------------------------------------------------
# Default: localhost:11434 with qwen2.5:1.5b. CPU-only by default
# (LLM_NUM_GPU=0) to avoid co-tenant GPU contention.
LLM_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:1.5b
LLM_NUM_GPU=0

# Per-Ollama-call timeout in seconds. Converts a stalled inference into a
# clean exception instead of a hang. Default 120.
# LLM_TIMEOUT_S=120

# --- Audit chain backend ------------------------------------------------------
# `live` (default) hits CYCLECORE_PQ_BASE_URL for real ML-DSA-65 signed entries.
# `stub` uses a local in-memory hash chain — useful for fully airgapped
# environments where no PQ API is reachable.
# PQ_AUDIT_BACKEND=live
